<configuration>

    <!-- File Appender -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <!-- Output file -->
        <file>logs/app-log.txt</file>

        <!-- Append instead of overwrite -->
        <append>false</append>

        <!-- Log format -->
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root logger -->
    <root level="DEBUG">
        <appender-ref ref="FILE"/>
    </root>

</configuration>